apiVersion: apps/v1
kind: Deployment
metadata:
  name: backend
  labels:
   app: multitool
spec:
  replicas: 3
  selector:
   matchLabels:
     app: multitool
  template:
   metadata:
     labels:
      app: multitool
   spec:
    containers:
     - name: multitool
       image: wbitt/network-multitool:openshift-extra
       ports:
       - containerPort: 1180
